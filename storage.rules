rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload to their own temp folder
    match /web_uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to upload/read radio images
    match /radio/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
